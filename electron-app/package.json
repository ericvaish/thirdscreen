{
  "name": "thirdscreen-desktop",
  "version": "0.1.0",
  "description": "Third Screen - Personal Dashboard (Desktop)",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"tsc -w\" \"electron .\"",
    "build": "tsc",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run dist -- --mac",
    "dist:win": "npm run dist -- --win",
    "dist:linux": "npm run dist -- --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "node-llama-cpp": "^3.18.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.thirdscreen.desktop",
    "productName": "Third Screen",
    "files": [
      "dist/**/*"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "directories": {
      "output": "release"
    }
  },
  "trustedDependencies": [
    "node-llama-cpp"
  ]
}
