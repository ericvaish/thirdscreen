---
import Layout from '../layouts/Layout.astro'
import '../styles/global.css'
---

<Layout title="Third Screen">

  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center px-6 bg-[#0a0a0a] overflow-hidden">

    <!-- Ambient glow behind screenshot -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/3 w-[900px] h-[500px] rounded-full bg-[#3b82f6]/8 blur-[120px] pointer-events-none" aria-hidden="true"></div>

    <!-- Nav -->
    <nav class="absolute top-0 inset-x-0 flex items-center justify-between max-w-6xl mx-auto px-6 py-6">
      <div class="flex items-center gap-3">
        <img src="/assets/thirdscreen_logo.svg" alt="Third Screen logo" class="w-8 h-8" />
        <span class="text-white font-semibold text-lg tracking-tight" style="font-family:Inter,system-ui,sans-serif;">Third Screen</span>
      </div>
      <div class="flex items-center gap-4">
        <a href="/app" class="text-sm text-white/60 hover:text-white transition-colors" style="font-family:Inter,system-ui,sans-serif;">Open Dashboard</a>
        <a href="https://github.com/ericvaish/thirdscreen/releases/latest/download/ThirdScreen-0.1.0.dmg" class="text-sm text-white/60 hover:text-white transition-colors" style="font-family:Inter,system-ui,sans-serif;">Download</a>
      </div>
    </nav>

    <!-- Headline -->
    <div class="relative z-10 text-center max-w-3xl mx-auto mt-16">
      <div class="inline-flex items-center gap-4 mb-4">
        <p class="text-[#3b82f6] text-sm font-medium tracking-widest uppercase" style="font-family:Inter,system-ui,sans-serif;">Native macOS Dashboard</p>
        <span class="text-white/20">|</span>
        <a href="https://github.com/ericvaish/thirdscreen" target="_blank" class="inline-flex items-center gap-1.5 text-white/40 hover:text-white/60 text-sm font-medium tracking-wide uppercase transition-colors" style="font-family:Inter,system-ui,sans-serif;">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Open Source
        </a>
      </div>
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold text-white tracking-tight leading-[1.08]" style="font-family:Inter,system-ui,sans-serif;">
        Your day, at a glance.
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-white/50 max-w-xl mx-auto leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">
        Second screen is scrolling your phone while the show runs in the background. Third Screen flips that model: one glance, all your ambient info.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="/app" class="inline-flex items-center gap-2 bg-white text-black font-semibold text-sm px-7 py-3 rounded-full hover:bg-white/90 transition-colors" style="font-family:Inter,system-ui,sans-serif;">
          Open Dashboard
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="https://github.com/ericvaish/thirdscreen/releases/latest/download/ThirdScreen-0.1.0.dmg" class="inline-flex items-center gap-2 text-sm text-white/50 hover:text-white/70 border border-white/10 hover:border-white/20 px-7 py-3 rounded-full transition-colors" style="font-family:Inter,system-ui,sans-serif;">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          Download for Mac
        </a>
        <a href="#features" class="text-sm text-white/40 hover:text-white/70 transition-colors" style="font-family:Inter,system-ui,sans-serif;">See features &darr;</a>
      </div>
    </div>

    <!-- Screenshot -->
    <div class="relative z-10 mt-16 mb-8 w-full max-w-5xl mx-auto">
      <div class="relative rounded-xl overflow-hidden shadow-2xl shadow-black/50 ring-1 ring-white/10">
        <img src="/assets/third_screen_demo.png" alt="Third Screen app screenshot showing the dashboard with multiple cards" class="w-full h-auto" />
      </div>
      <!-- Reflected glow under screenshot -->
      <div class="absolute -bottom-12 left-1/2 -translate-x-1/2 w-3/4 h-24 bg-[#3b82f6]/6 blur-[60px] rounded-full pointer-events-none" aria-hidden="true"></div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- FEATURES (10 Card Types)                     -->
  <!-- ============================================ -->
  <section id="features" class="relative bg-[#0a0a0a] py-32 px-6">
    <div class="max-w-6xl mx-auto">

      <div class="reveal text-center mb-20">
        <p class="text-[#3b82f6] text-sm font-medium tracking-widest uppercase mb-3" style="font-family:Inter,system-ui,sans-serif;">Cards</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-white tracking-tight" style="font-family:Inter,system-ui,sans-serif;">Everything you need. Nothing you don't.</h2>
        <p class="mt-4 text-white/40 text-lg max-w-xl mx-auto" style="font-family:Inter,system-ui,sans-serif;">Ten card types. Drag, resize, and duplicate them to build your perfect dashboard.</p>
      </div>

      <div class="reveal-stagger grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        <!-- Card: Timer -->
        <div class="reveal group relative bg-[#111] rounded-2xl p-6 ring-1 ring-white/[0.06] hover:ring-white/[0.12] transition-all duration-300 hover:bg-[#161616]">
          <div class="text-3xl mb-4">&#9200;</div>
          <h3 class="text-white font-semibold text-sm" style="font-family:Inter,system-ui,sans-serif;">Timer</h3>
          <p class="text-white/35 text-xs mt-1 leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Clock, timer, alarm & world time</p>
        </div>

        <!-- Card: Media -->
        <div class="reveal group relative bg-[#111] rounded-2xl p-6 ring-1 ring-white/[0.06] hover:ring-white/[0.12] transition-all duration-300 hover:bg-[#161616]">
          <div class="text-3xl mb-4">&#127925;</div>
          <h3 class="text-white font-semibold text-sm" style="font-family:Inter,system-ui,sans-serif;">Media</h3>
          <p class="text-white/35 text-xs mt-1 leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Spotify now playing + lyrics</p>
        </div>

        <!-- Card: Schedule -->
        <div class="reveal group relative bg-[#111] rounded-2xl p-6 ring-1 ring-white/[0.06] hover:ring-white/[0.12] transition-all duration-300 hover:bg-[#161616]">
          <div class="text-3xl mb-4">&#128197;</div>
          <h3 class="text-white font-semibold text-sm" style="font-family:Inter,system-ui,sans-serif;">Schedule</h3>
          <p class="text-white/35 text-xs mt-1 leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Meetings, events & timeline</p>
        </div>

        <!-- Card: Battery -->
        <div class="reveal group relative bg-[#111] rounded-2xl p-6 ring-1 ring-white/[0.06] hover:ring-white/[0.12] transition-all duration-300 hover:bg-[#161616]">
          <div class="text-3xl mb-4">&#128267;</div>
          <h3 class="text-white font-semibold text-sm" style="font-family:Inter,system-ui,sans-serif;">Battery</h3>
          <p class="text-white/35 text-xs mt-1 leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Device & Bluetooth levels</p>
        </div>

        <!-- Card: Food Tracking -->
        <div class="reveal group relative bg-[#111] rounded-2xl p-6 ring-1 ring-white/[0.06] hover:ring-white/[0.12] transition-all duration-300 hover:bg-[#161616]">
          <div class="text-3xl mb-4">&#128293;</div>
          <h3 class="text-white font-semibold text-sm" style="font-family:Inter,system-ui,sans-serif;">Food Tracking</h3>
          <p class="text-white/35 text-xs mt-1 leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Calories, meals & water intake</p>
        </div>

        <!-- Card: Shortcuts -->
        <div class="reveal group relative bg-[#111] rounded-2xl p-6 ring-1 ring-white/[0.06] hover:ring-white/[0.12] transition-all duration-300 hover:bg-[#161616]">
          <div class="text-3xl mb-4">&#9889;</div>
          <h3 class="text-white font-semibold text-sm" style="font-family:Inter,system-ui,sans-serif;">Shortcuts</h3>
          <p class="text-white/35 text-xs mt-1 leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Run Apple Shortcuts</p>
        </div>

        <!-- Card: Todos -->
        <div class="reveal group relative bg-[#111] rounded-2xl p-6 ring-1 ring-white/[0.06] hover:ring-white/[0.12] transition-all duration-300 hover:bg-[#161616]">
          <div class="text-3xl mb-4">&#9989;</div>
          <h3 class="text-white font-semibold text-sm" style="font-family:Inter,system-ui,sans-serif;">Todos</h3>
          <p class="text-white/35 text-xs mt-1 leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Apple Reminders tasks</p>
        </div>

        <!-- Card: Notes -->
        <div class="reveal group relative bg-[#111] rounded-2xl p-6 ring-1 ring-white/[0.06] hover:ring-white/[0.12] transition-all duration-300 hover:bg-[#161616]">
          <div class="text-3xl mb-4">&#128221;</div>
          <h3 class="text-white font-semibold text-sm" style="font-family:Inter,system-ui,sans-serif;">Notes</h3>
          <p class="text-white/35 text-xs mt-1 leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Quick notes & scratch pad</p>
        </div>

        <!-- Card: Medicines -->
        <div class="reveal group relative bg-[#111] rounded-2xl p-6 ring-1 ring-white/[0.06] hover:ring-white/[0.12] transition-all duration-300 hover:bg-[#161616]">
          <div class="text-3xl mb-4">&#128138;</div>
          <h3 class="text-white font-semibold text-sm" style="font-family:Inter,system-ui,sans-serif;">Medicines</h3>
          <p class="text-white/35 text-xs mt-1 leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Medication tracking</p>
        </div>

        <!-- Card: AI Chat -->
        <div class="reveal group relative bg-[#111] rounded-2xl p-6 ring-1 ring-white/[0.06] hover:ring-white/[0.12] transition-all duration-300 hover:bg-[#161616]">
          <div class="text-3xl mb-4">&#129302;</div>
          <h3 class="text-white font-semibold text-sm" style="font-family:Inter,system-ui,sans-serif;">AI Chat</h3>
          <p class="text-white/35 text-xs mt-1 leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Local LLM, fully private</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- KEY CAPABILITIES                             -->
  <!-- ============================================ -->
  <section class="relative bg-[#0a0a0a] py-32 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="reveal text-center mb-16">
        <p class="text-[#3b82f6] text-sm font-medium tracking-widest uppercase mb-3" style="font-family:Inter,system-ui,sans-serif;">Built Different</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-white tracking-tight" style="font-family:Inter,system-ui,sans-serif;">Designed for the way you work.</h2>
      </div>

      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="reveal bg-[#111] rounded-2xl p-8 ring-1 ring-white/[0.06]">
          <div class="w-10 h-10 rounded-xl bg-[#3b82f6]/10 flex items-center justify-center text-[#3b82f6] text-lg mb-5">&#8596;</div>
          <h3 class="text-white font-semibold mb-2" style="font-family:Inter,system-ui,sans-serif;">Drag & Resize</h3>
          <p class="text-white/40 text-sm leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Every card is draggable and resizable. Arrange your dashboard exactly the way you want it.</p>
        </div>

        <div class="reveal bg-[#111] rounded-2xl p-8 ring-1 ring-white/[0.06]">
          <div class="w-10 h-10 rounded-xl bg-[#3b82f6]/10 flex items-center justify-center text-[#3b82f6] text-lg mb-5">&#10697;</div>
          <h3 class="text-white font-semibold mb-2" style="font-family:Inter,system-ui,sans-serif;">Multiple Instances</h3>
          <p class="text-white/40 text-sm leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Need two timers? Three notes? Add multiple instances of the same card type.</p>
        </div>

        <div class="reveal bg-[#111] rounded-2xl p-8 ring-1 ring-white/[0.06]">
          <div class="w-10 h-10 rounded-xl bg-[#3b82f6]/10 flex items-center justify-center text-[#3b82f6] text-lg mb-5">&#9776;</div>
          <h3 class="text-white font-semibold mb-2" style="font-family:Inter,system-ui,sans-serif;">Layout Profiles</h3>
          <p class="text-white/40 text-sm leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Save and switch between layout profiles. One for work, one for home, one for focus.</p>
        </div>

        <div class="reveal bg-[#111] rounded-2xl p-8 ring-1 ring-white/[0.06]">
          <div class="w-10 h-10 rounded-xl bg-[#3b82f6]/10 flex items-center justify-center text-[#3b82f6] text-lg mb-5">&#9790;</div>
          <h3 class="text-white font-semibold mb-2" style="font-family:Inter,system-ui,sans-serif;">Dark, Light & Auto</h3>
          <p class="text-white/40 text-sm leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Follows your system appearance or override it. Beautiful in both modes.</p>
        </div>

        <div class="reveal bg-[#111] rounded-2xl p-8 ring-1 ring-white/[0.06]">
          <div class="w-10 h-10 rounded-xl bg-[#3b82f6]/10 flex items-center justify-center text-[#3b82f6] text-lg mb-5">&#9881;</div>
          <h3 class="text-white font-semibold mb-2" style="font-family:Inter,system-ui,sans-serif;">Native SwiftUI</h3>
          <p class="text-white/40 text-sm leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Built natively for macOS with SwiftUI. No Electron. No web views. Instant performance.</p>
        </div>

        <div class="reveal bg-[#111] rounded-2xl p-8 ring-1 ring-white/[0.06]">
          <div class="w-10 h-10 rounded-xl bg-[#3b82f6]/10 flex items-center justify-center text-[#3b82f6] text-lg mb-5">&#128274;</div>
          <h3 class="text-white font-semibold mb-2" style="font-family:Inter,system-ui,sans-serif;">Privacy First</h3>
          <p class="text-white/40 text-sm leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">All data stays on your Mac. AI Chat runs a local LLM. No telemetry, no tracking.</p>
        </div>

        <div class="reveal bg-[#111] rounded-2xl p-8 ring-1 ring-white/[0.06]">
          <div class="w-10 h-10 rounded-xl bg-[#3b82f6]/10 flex items-center justify-center text-[#3b82f6] text-lg mb-5">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2" style="font-family:Inter,system-ui,sans-serif;">Open Source</h3>
          <p class="text-white/40 text-sm leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">Every line of code is public on GitHub. Inspect it, fork it, contribute to it.</p>
        </div>

        <div class="reveal bg-[#111] rounded-2xl p-8 ring-1 ring-white/[0.06]">
          <div class="w-10 h-10 rounded-xl bg-[#3b82f6]/10 flex items-center justify-center text-[#3b82f6] text-lg mb-5">&#128241;</div>
          <h3 class="text-white font-semibold mb-2" style="font-family:Inter,system-ui,sans-serif;">iPhone & iPad</h3>
          <p class="text-white/40 text-sm leading-relaxed" style="font-family:Inter,system-ui,sans-serif;">iOS and iPadOS apps are in the works. Coming soon.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- INTEGRATIONS                                 -->
  <!-- ============================================ -->
  <section class="relative bg-[#0a0a0a] py-28 px-6">
    <div class="reveal max-w-4xl mx-auto text-center">
      <p class="text-[#3b82f6] text-sm font-medium tracking-widest uppercase mb-3" style="font-family:Inter,system-ui,sans-serif;">Integrations</p>
      <h2 class="text-4xl sm:text-5xl font-bold text-white tracking-tight mb-6" style="font-family:Inter,system-ui,sans-serif;">Connects to what you already use.</h2>
      <p class="text-white/40 text-lg mb-16 max-w-lg mx-auto" style="font-family:Inter,system-ui,sans-serif;">No setup. No configuration. Just works with your existing apps and services.</p>

      <div class="flex flex-wrap items-center justify-center gap-4">
        <div class="flex items-center gap-2.5 bg-[#1a1a1a] rounded-full px-5 py-2.5 ring-1 ring-white/[0.06]">
          <svg class="w-5 h-5 text-[#1DB954]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
          <span class="text-white/70 text-sm font-medium" style="font-family:Inter,system-ui,sans-serif;">Spotify</span>
        </div>

        <div class="flex items-center gap-2.5 bg-[#1a1a1a] rounded-full px-5 py-2.5 ring-1 ring-white/[0.06]">
          <svg class="w-5 h-5 text-[#4285F4]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zm-1-6v-2h2v2h-2zm0-4V8h2v4h-2z" opacity="0.3"/><path d="M19.5 3.5L18 2l-1.5 1.5L15 2l-1.5 1.5L12 2l-1.5 1.5L9 2 7.5 3.5 6 2v14H3v3c0 1.66 1.34 3 3 3h12c1.66 0 3-1.34 3-3V2l-1.5 1.5zM15 20H6c-.55 0-1-.45-1-1v-1h10v2zm4-1c0 .55-.45 1-1 1s-1-.45-1-1v-3H8V5h11v14z"/><path d="M9 7h6v2H9zm0 4h6v2H9z"/></svg>
          <span class="text-white/70 text-sm font-medium" style="font-family:Inter,system-ui,sans-serif;">Google Calendar</span>
        </div>

        <div class="flex items-center gap-2.5 bg-[#1a1a1a] rounded-full px-5 py-2.5 ring-1 ring-white/[0.06]">
          <svg class="w-5 h-5 text-white/60" viewBox="0 0 24 24" fill="currentColor"><path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z"/></svg>
          <span class="text-white/70 text-sm font-medium" style="font-family:Inter,system-ui,sans-serif;">Apple Calendar</span>
