---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Your day, at a glance, in a single dashboard. A native macOS app that puts your time, music, schedule, todos, and more in one beautiful view." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/assets/thirdscreen_logo.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Eric Vaish" />
    <title>{title}</title>

    <!-- Author link -->
    <link rel="author" href="https://ericvaish.com" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/assets/third_screen_demo.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/assets/third_screen_demo.png" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Third Screen",
      "operatingSystem": "macOS",
      "applicationCategory": "UtilitiesApplication",
      "description": description,
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Person",
        "name": "Eric Vaish",
        "url": "https://ericvaish.com",
        "sameAs": [
          "https://github.com/ericvaish",
          "https://ericvaish.com"
        ]
      },
      "url": "https://thirdscreen.app",
      "downloadUrl": "https://github.com/ericvaish/thirdscreen/releases/latest/download/ThirdScreen-0.1.0.dmg",
      "screenshot": "/assets/third_screen_demo.png",
      "softwareVersion": "0.1.0",
      "isAccessibleForFree": true
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />

    <script>
      import Lenis from 'lenis'

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      })

      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          e.preventDefault()
          const target = document.querySelector((anchor as HTMLAnchorElement).getAttribute('href')!)
          if (target) {
            lenis.scrollTo(target as HTMLElement, { offset: 0 })
          }
        })
      })

      function raf(time: number) {
        lenis.raf(time)
        requestAnimationFrame(raf)
      }
      requestAnimationFrame(raf)

      // Scroll-reveal observer
      const reveals = document.querySelectorAll('.reveal')
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed')
              observer.unobserve(entry.target)
            }
          })
        },
        { threshold: 0.15 }
      )
      reveals.forEach((el) => observer.observe(el))
    </script>
  </body>
</html>
